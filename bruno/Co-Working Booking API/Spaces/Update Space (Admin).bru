}

put {
  url: {{baseUrl}}/spaces/{{spaceId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "pricePerHour": 32.5,
    "amenities": ["WiFi", "Whiteboard", "Monitor", "Standing Desk"]
  }
}

